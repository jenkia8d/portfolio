npm create vite@latest recipe_saver -- --template react
npm install
npm run dev

# src/App.jsx:

import './App.css'

function App() {
  return (
    <main className="app">
      <section className="hero">
        <h1>Recipe Saver</h1>
        <p>Save recipes from browser tabs into one organized place.</p>
      </section>
    </main>
  )
}

export default App


